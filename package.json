{
  "name": "moistly",
  "version": "1.0.0",
  "description": "**Foundry is a blazing fast, portable and modular toolkit for Ethereum application development written in Rust.**",
  "main": "truffle-config.js",
  "directories": {
    "lib": "lib",
    "test": "test"
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "ganache": "ganache  --mnemonic 'survey round advance myth torch health boost embrace bacon expect circle kid' --unlock 0x5B38Da6a701c568545dCfcB03FcB875f56beddC4 --unlock 0xAb8483F64d9C6d1EcF9b849Ae677dD3315835cb2 --unlock 0xCA35b7d915458EF540aDe6068dFe2F44E8fa733c --unlock 0x14723A09ACff6D2A60DcDF7aA4AFf308FDDC160C --unlock 0x4B0897b0513fdc7C541B6d9D7E929C4e5364D2dB --unlock 0x583031D1113aD414F02576BD6afaBfb302140225 --unlock 0xdD870fA1b7C4700F2BD7f44238821C26f7392148 --unlock 0x8626f6940E2eb28930eFb4CeF49B2d1F2C9C1199 --unlock 0x90F79bf6EB2c4f870365E785982E1f101E93b906 --unlock 0xFFcf8FDEE72ac11b5c542428B35EEF5769C409f0",
    "ganache:start": "./start_ganache.sh",
    "ganache:config": "ganache --config ganache-config.js --logging.verbose --mnemonic 'survey round advance myth torch health boost embrace bacon expect circle kid'",
    "foundry:status": "node node/foundry-status.mjs",
    "anvil:start": "anvil --host 127.0.0.1 --port 8545",
    "db:up": "docker compose --env-file .env.mssql up -d mssql mssql-init",
    "db:down": "docker compose --env-file .env.mssql down",
    "db:logs": "docker compose --env-file .env.mssql logs -f mssql",
    "ganache:index": "node --env-file=.env.mssql node/index-ganache-to-mssql.mjs",
    "ganache:index:once": "node --env-file=.env.mssql node/index-ganache-to-mssql.mjs --once",
    "deploy:moist-stack": "node scripts/deploy-moist-beacon-executor-create3.mjs",
    "deploy:moist-stack:broadcast": "node scripts/deploy-moist-beacon-executor-create3.mjs --broadcast",
    "deploy:moist-stack:base": "node scripts/deploy-moist-beacon-executor-create3.mjs --chain base",
    "deploy:moist-stack:base:broadcast": "node scripts/deploy-moist-beacon-executor-create3.mjs --chain base --broadcast",
    "deploy:moist-stack:arbitrum": "node scripts/deploy-moist-beacon-executor-create3.mjs --chain arbitrum",
    "deploy:moist-stack:arbitrum:broadcast": "node scripts/deploy-moist-beacon-executor-create3.mjs --chain arbitrum --broadcast",
    "deploy:moist-swapper-controller": "node scripts/deploy-moist-swapper-controller-create3.mjs",
    "deploy:moist-swapper-controller:broadcast": "node scripts/deploy-moist-swapper-controller-create3.mjs --broadcast",
    "verify:moist-stack": "node scripts/verify-moist-full-stack-blockscout.mjs",
    "verify:moist-stack:etherscan": "node scripts/verify-moist-full-stack-blockscout.mjs --etherscan",
    "deploy:moist-beacon": "npm run deploy:moist-stack",
    "deploy:moist-beacon:broadcast": "npm run deploy:moist-stack:broadcast",
    "initialize:moist-proxy": "node scripts/initialize-moist-proxy.mjs",
    "deploy:collector": "truffle migrate --network development --f 2 --to 2",
    "collect:eth": "truffle exec scripts/collect_eth.js --network development"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ItsMoist/Moistly.git"
  },
  "keywords": [],
  "author": "Benjamin Nelligan",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/ItsMoist/Moistly/issues"
  },
  "homepage": "https://github.com/ItsMoist/Moistly#readme",
  "dependencies": {
    "@ensdomains/ens-contracts": "^1.7.0",
    "@ethersproject/bignumber": "^5.8.0",
    "@metamask/connect-evm": "^2.1.1",
    "@metamask/connect-multichain": "^1.2.0",
    "@openzeppelin/contracts": "^5.6.1",
    "@truffle/config": "^1.3.61",
    "@truffle/core": "^5.11.5",
    "@truffle/hdwallet-provider": "^1.7.0",
    "brownie": "^0.9.9",
    "ether-router": "^0.4.0",
    "ganache": "^7.9.2",
    "ganache-cli": "^6.12.2",
    "mssql": "^12.7.0",
    "node-gyp-build": "^4.8.4",
    "solc": "^0.8.36",
    "truffle": "^5.11.5",
    "truffle-security": "^1.7.3",
    "uws": "^200.0.0",
    "viem": "^2.55.4",
    "web3": "^4.16.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ethers": "^4.0.15",
    "@nomicfoundation/hardhat-ignition": "^3.1.8",
    "@nomicfoundation/hardhat-toolbox-mocha-ethers": "^3.0.7",
    "@openzeppelin/hardhat-upgrades": "^4.0.2",
    "@truffle/core": "^5.11.5",
    "@types/chai": "^5.2.3",
    "@types/chai-as-promised": "^8.0.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.20.1",
    "chai": "^6.2.2",
    "ethers": "^6.17.0",
    "forge-std": "github:foundry-rs/forge-std#v1.9.4",
    "hardhat": "^3.11.0",
    "mocha": "^11.7.6",
    "truffle-plugin-verify": "^0.6.7",
    "typescript": "~6.0.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0",
    "runtime": ">=18.0.0",
    "python": ">=3.10.0"
  },
  "type": "module"
}
